# ── OpenMandi server (Phase 2). Copy to .env and fill. NEVER commit .env. ──

PORT=8787
NODE_ENV=development

# Supabase (@supabase/server SDK). Copy real values from the dashboard's
# Connect dialog. The SECRET key is server-only — NEVER commit it or ship it.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# (Legacy Express scaffold only) service-role key + JWT audience
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...
SUPABASE_JWT_AUD=authenticated

# CORS allowlist (comma-separated origins that may call this API)
CORS_ORIGINS=http://localhost:5173,http://localhost:5179

# App-level encryption key for sensitive columns (bank details etc.)
# 32-byte base64; generate: openssl rand -base64 32
DATA_ENC_KEY=

# Razorpay (escrow). Use test keys in sandbox.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Aadhaar / GST KYC via a UIDAI-LICENSED provider (Setu / Cashfree / Sandbox.co.in /
# Signzy / IDfy / Digio). DO NOT call UIDAI directly. Sandbox creds for demo.
KYC_PROVIDER=sandbox
KYC_API_BASE=
KYC_API_KEY=
KYC_API_SECRET=

# data.gov.in Agmarknet API key for mandi-price ingestion
DATAGOV_API_KEY=
